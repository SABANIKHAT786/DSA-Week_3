Compartment.java

public abstract class Compartment  {
    public abstract String notice();
    // print notice when a Compartment is constructed
    public Compartment() {
        System.out.println("Notice issued");
    }
}

FirstClass.java

public class FirstClass extends Compartment{
    @Override
    public String notice(){
        return "This is FirstClass Compartment";
    }
}

